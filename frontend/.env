# ============================================================
# API CONFIGURATION
# ============================================================

# Backend API URL (development)
VITE_API_URL=http://localhost:5000/api/v1

# Backend API URL (production - uncomment when deploying)
# VITE_API_URL=https://api.ethiotrans.com/api/v1

# API Timeout in milliseconds
VITE_API_TIMEOUT=30000

# ============================================================
# APP CONFIGURATION
# ============================================================

# Application name
VITE_APP_NAME=EthioTrans

# Application version
VITE_APP_VERSION=1.0.0

# Application environment
VITE_APP_ENV=development

# ============================================================
# FEATURE FLAGS
# ============================================================

# Enable mock API (for development without backend)
VITE_ENABLE_MOCK_API=false

# Enable debug mode (shows console logs)
VITE_DEBUG_MODE=true

# Enable dark mode by default
VITE_DEFAULT_DARK_MODE=false

# ============================================================
# PAYMENT CONFIGURATION
# ============================================================

# Telebirr API URL (for payment integration)
VITE_TELEBIRR_API_URL=https://api.telebirr.et/v1

# CBEBirr API URL
VITE_CBEBIRR_API_URL=https://api.cbebirr.et/v1

# ============================================================
# MAPS & LOCATION (Optional)
# ============================================================

# Map provider (leaflet, google, etc.)
VITE_MAP_PROVIDER=leaflet

# Google Maps API Key (if using Google Maps)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# Sentry DSN (for error tracking)
# VITE_SENTRY_DSN=your_sentry_dsn_url

# ============================================================
# PWA CONFIGURATION (Optional)
# ============================================================

# Enable PWA
VITE_ENABLE_PWA=false

# ============================================================
# MAINTENANCE MODE
# ============================================================

# Enable maintenance mode
VITE_MAINTENANCE_MODE=false

# Maintenance message
VITE_MAINTENANCE_MESSAGE=System is under maintenance. Please check back later.